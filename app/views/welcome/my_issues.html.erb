<div class="container mx-auto flex flex-col bg-gray-50 dark:bg-gray-800 min-h-full">

  <div class="flex flex-col md:flex-row mt-8 md:mt-24">
    <%= render "welcome/tabs" %>

    <div class="md:ml-44 lg:ml-64 px-6 lg:px-12 bg-gray-50 dark:bg-gray-800 rounded-lg w-full pb-12">

      <%# ── Demandes assignées ───────────────────────────────────────── %>
      <% if @my_issues.length > 0 %>
        <section class="mb-10">
          <h2 class="mb-4 text-xs text-gray-400 dark:text-gray-500 font-medium uppercase tracking-wider flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
            </svg>
            <%= l("welcome.my_assigned_issues.title") %>
            <span class="ml-1 text-gray-300 dark:text-gray-600 font-normal normal-case">(<%= @my_issues_total %>)</span>
          </h2>

          <div class="flex flex-col gap-1">
            <% @my_issues.each do |issue| %>
              <%= link_to issue_path(issue), class: "group flex items-center gap-3 bg-white dark:bg-gray-700 shadow rounded-lg px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-600 transition" do %>

                <%# Indicateur de priorité %>
                <% priority_color = case issue.priority.try(:position)
                   when 1 then "bg-gray-300 dark:bg-gray-500"
                   when 2 then "bg-blue-400"
                   when 3 then "bg-amber-400"
                   when 4 then "bg-orange-500"
                   else        "bg-red-600"
                   end %>
                <span class="w-1.5 h-8 rounded-full shrink-0 <%= priority_color %>"></span>

                <%# Contenu principal %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-xs text-gray-400 dark:text-gray-500 shrink-0"><%= issue.tracker %> #<%= issue.id %></span>
                    <span class="text-xs text-gray-300 dark:text-gray-600 truncate"><%= issue.project %></span>
                  </div>
                  <p class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate group-hover:text-blue-600 dark:group-hover:text-blue-400"><%= issue.subject %></p>
                </div>

                <%# Statut %>
                <span class="hidden sm:inline-flex shrink-0 text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-600 text-gray-600 dark:text-gray-300"><%= issue.status %></span>

                <%# Date d'échéance %>
                <% if issue.due_date %>
                  <% if issue.overdue? %>
                    <span class="hidden md:flex shrink-0 items-center gap-1 text-xs font-medium text-red-600 dark:text-red-400">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                      </svg>
                      <%= format_date(issue.due_date) %>
                    </span>
                  <% else %>
                    <span class="hidden md:flex shrink-0 items-center gap-1 text-xs text-gray-400 dark:text-gray-500">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                      </svg>
                      <%= format_date(issue.due_date) %>
                    </span>
                  <% end %>
                <% end %>

              <% end %>
            <% end %>
          </div>

          <% if @my_issues_total > @my_issues.length %>
            <div class="mt-3 text-center">
              <%= link_to issues_path(assigned_to_id: 'me', status_id: 'o'), class: "text-xs text-blue-500 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300" do %>
                <%= l("welcome.issues.see_all", count: @my_issues_total) %>
              <% end %>
            </div>
          <% end %>
        </section>
      <% end %>

      <%# ── Demandes observées ───────────────────────────────────────── %>
      <% if @observed_issues.length > 0 %>
        <section>
          <h2 class="mb-4 text-xs text-gray-400 dark:text-gray-500 font-medium uppercase tracking-wider flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            <%= l("welcome.my_watched_issues.title") %>
            <span class="ml-1 text-gray-300 dark:text-gray-600 font-normal normal-case">(<%= @observed_issues_total %>)</span>
          </h2>

          <div class="flex flex-col gap-1">
            <% @observed_issues.each do |issue| %>
              <%= link_to issue_path(issue), class: "group flex items-center gap-3 bg-white dark:bg-gray-700 shadow rounded-lg px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-600 transition" do %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-xs text-gray-400 dark:text-gray-500 shrink-0"><%= issue.tracker %> #<%= issue.id %></span>
                    <span class="text-xs text-gray-300 dark:text-gray-600 truncate"><%= issue.project %></span>
                  </div>
                  <p class="text-sm font-medium text-gray-800 dark:text-gray-200 truncate group-hover:text-blue-600 dark:group-hover:text-blue-400"><%= issue.subject %></p>
                </div>
                <span class="hidden sm:inline-flex shrink-0 text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-600 text-gray-600 dark:text-gray-300"><%= issue.status %></span>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if @my_issues.empty? && @observed_issues.empty? %>
        <div class="flex flex-col items-center justify-center py-24 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-gray-200 dark:text-gray-700 mb-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <p class="text-sm font-medium text-gray-400 dark:text-gray-500"><%= l("welcome.issues.none") %></p>
        </div>
      <% end %>

    </div>
  </div>
</div>
