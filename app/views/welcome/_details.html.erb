<%# locals: project, jump_box, open_count, children_count, project_with_trackers, logo, bookmarked_section %>
<% bookmarked = jump_box.bookmark?(project) %>
<% tracker_project = project_with_trackers || project %>
<% bookmarked_section ||= false %>

<div data-controller="projects"
     data-projects-url-value="<%= home_project_path(project.id) %>"
     style="display:flex;flex-direction:column;min-height:0;"
     class="bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-md hover:border-gray-200 dark:hover:border-gray-600 transition group overflow-hidden">

  <%# ── Body (logo + nom + méta) ─────────────────────────────────────── %>
  <div style="flex:1;" class="px-4 pt-6 pb-3">

    <%# Logo + nom alignés %>
    <div style="display:flex;align-items:center;gap:10px;">

      <%# Avatar 36×36 strict %>
      <div style="width:36px;height:36px;min-width:36px;max-width:36px;min-height:36px;max-height:36px;overflow:hidden;border-radius:8px;flex-shrink:0;background:#f3f4f6;position:relative;">
        <% if logo %>
          <img src="<%= asap_project_logo_path(project) %>"
               alt="<%= project.name %>"
               style="position:absolute;top:0;left:0;width:36px;height:36px;object-fit:contain;" />
        <% else %>
          <%= letter_avatar_tag(project.name, 300, style: 'position:absolute;top:0;left:0;width:36px;height:36px;max-width:36px;max-height:36px;border-radius:0;') %>
        <% end %>
      </div>

      <%# Nom + sous-projets (colonne) %>
      <div style="flex:1;min-width:0;">
        <%= link_to project_path(project),
              style: "font-weight:500;font-size:0.875rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;",
              class: "text-gray-800 dark:text-gray-100 hover:text-blue-600 dark:hover:text-blue-400" do %>
          <%= project.name %>
        <% end %>
        <% if children_count > 0 %>
          <span style="font-size:0.7rem;color:#9ca3af;display:flex;align-items:center;gap:3px;margin-top:2px;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"
                 style="width:10px;height:10px;min-width:10px;flex-shrink:0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
            </svg>
            <%= l(:label_subprojects_count, count: children_count) %>
          </span>
        <% end %>
      </div>
    </div>

  </div>

  <%# ── Footer : actions ────────────────────────────────────────────── %>
  <div style="display:flex;align-items:center;gap:2px;padding:6px 12px;border-top:1px solid #f3f4f6;flex-shrink:0;">

    <% if User.current.allowed_to?(:add_issues, project) && tracker_project.trackers.any? %>
      <%= link_to new_project_issue_path(project),
            title: l(:label_issue_new),
            style: "padding:6px;border-radius:8px;display:flex;color:#d1d5db;",
            class: "hover:text-blue-600 hover:bg-blue-50 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"
             style="width:16px;height:16px;min-width:16px;flex-shrink:0;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      <% end %>
    <% end %>

    <% if User.current.allowed_to?(:edit_project, project) %>
      <%= link_to settings_project_path(project),
            title: l(:label_settings),
            style: "padding:6px;border-radius:8px;display:flex;color:#d1d5db;",
            class: "hover:text-gray-600 hover:bg-gray-100 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
             style="width:16px;height:16px;min-width:16px;flex-shrink:0;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        </svg>
      <% end %>
    <% end %>

    <%# Favori %>
    <% if bookmarked %>
      <%= link_to welcome_bookmark_project_delete_path(project.id), method: :delete,
            title: l(:button_unwatch),
            style: "padding:6px;border-radius:8px;display:flex;color:#fbbf24;",
            class: "hover:text-gray-400 hover:bg-gray-100 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
             style="width:16px;height:16px;min-width:16px;flex-shrink:0;">
          <path fill-rule="evenodd" d="M6.32 2.577a49.255 49.255 0 0 1 11.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 0 1-1.085.67L12 18.089l-7.165 3.583A.75.75 0 0 1 3.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93Z" clip-rule="evenodd" />
        </svg>
      <% end %>
    <% else %>
      <%= link_to welcome_bookmark_project_path(project.id), method: :post,
            title: l(:button_watch),
            style: "padding:6px;border-radius:8px;display:flex;color:#d1d5db;",
            class: "hover:text-amber-400 hover:bg-amber-50 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
             style="width:16px;height:16px;min-width:16px;flex-shrink:0;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0Z" />
        </svg>
      <% end %>
    <% end %>

    <%# Chevron → ouvre le side panel %>
    <button data-action="click->projects#openSidePanel"
            data-project-name="<%= project.name %>"
            data-project-logo-url="<%= logo ? asap_project_logo_path(project) : '' %>"
            style="margin-left:auto;padding:6px;border-radius:8px;display:flex;cursor:pointer;color:#d1d5db;background:none;border:none;"
            class="hover:text-gray-500 hover:bg-gray-100 transition"
            title="<%= l('welcome.accordion.toggle') %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           stroke-width="2" stroke="currentColor"
           style="width:16px;height:16px;min-width:16px;flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
      </svg>
    </button>
  </div>

</div>
