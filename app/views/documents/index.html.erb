<div class="contextual">
<%= link_to sprite_icon('add', l(:label_document_new)), new_project_document_path(@project), :class => 'icon icon-add',
            :onclick => 'showAndScrollTo("add-document", "document_title"); return false;' if User.current.allowed_to?(:add_documents, @project) %>
</div>

<div id="add-document" style="display:none;">
<h2><%=l(:label_document_new)%></h2>
<%= labelled_form_for @document, :url => project_documents_path(@project), :html => {:multipart => true} do |f| %>
<%= render :partial => 'form', :locals => {:f => f} %>
<p>
  <%= submit_tag l(:button_create) %>
  <%= link_to l(:button_cancel), "#", :onclick => '$("#add-document").hide(); return false;' %>
</p>
<% end %>
</div>

<h2><%=l(:label_document_plural)%></h2>

<div id="document-list" data-controller="documents">
<% if @grouped.empty? %>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>

<% sorted_groups = case @sort_by
  when 'date' then @grouped.keys.sort.reverse
  when 'category' then @grouped.keys.sort_by { |g| [g.nil? ? 1 : 0, g&.name.to_s] }
  when 'author' then @grouped.keys.sort_by { |g| g&.name.to_s }
  else @grouped.keys.sort_by(&:to_s)
end %>
<% sorted_groups.each do |group| %>
  <%
    cat_id = group.respond_to?(:id) ? group.id.to_s : group.to_s.parameterize
    cat_name = group.respond_to?(:name) ? group.name : group.to_s
  %>
  <div class="docs-folder" data-documents-target="category" data-category-id="<%= cat_id %>">
    <div class="docs-folder__header" data-action="click->documents#toggle">
      <span class="docs-chevron" data-documents-target="chevron">&#9660;</span>
      <span class="docs-folder__icon">&#128193;</span>
      <span class="docs-folder__name"><%= cat_name %></span>
      <span class="docs-folder__count"><%= @grouped[group].size %></span>
    </div>
    <div class="docs-folder__body" data-documents-target="body">
      <% @grouped[group].each do |document| %>
        <div class="docs-doc">
          <div class="docs-doc__header">
            <span class="docs-doc__icon">&#128196;</span>
            <span class="docs-doc__title">
              <%= link_to document.title, document_path(document) %>
            </span>
            <span class="docs-doc__meta"><%= format_date(document.updated_on) %></span>
          </div>
          <% if document.description.present? %>
            <div class="docs-doc__description">
              <%= textilizable(truncate_lines(document.description, length: 200), :object => document) %>
            </div>
          <% end %>
          <% if document.attachments.any? %>
            <div class="docs-doc__files">
              <% document.attachments.each do |att| %>
                <div class="docs-file">
                  <span class="docs-file__icon">&#128206;</span>
                  <%= link_to att.filename, download_named_attachment_path(att, att.filename), class: 'docs-file__name' %>
                  <span class="docs-file__size"><%= number_to_human_size(att.filesize) %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
</div>

<% content_for :sidebar do %>
  <h3><%= l(:label_sort_by, '') %></h3>
  <ul>
    <li><%= link_to(l(:field_category), {:sort_by => 'category'}, :class => (@sort_by == 'category' ? 'selected' : nil)) %></li>
    <li><%= link_to(l(:label_date), {:sort_by => 'date'}, :class => (@sort_by == 'date' ? 'selected' : nil)) %></li>
    <li><%= link_to(l(:field_title), {:sort_by => 'title'}, :class => (@sort_by == 'title' ? 'selected' : nil)) %></li>
    <li><%= link_to(l(:field_author), {:sort_by => 'author'}, :class => (@sort_by == 'author' ? 'selected' : nil)) %></li>
  </ul>
<% end %>

<% html_title(l(:label_document_plural)) -%>
