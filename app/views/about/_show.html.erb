<div data-application-target="modal" id="default-modal" tabindex="-1" aria-hidden="true"
     class="flex items-center justify-center bg-gray-900/60 backdrop-blur-sm fixed inset-0 z-50 p-4">
  <div data-application-target="modalBody" class="relative w-full max-w-sm">

    <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden">

      <%# Header avec logo sur fond neutre %>
      <div class="bg-gray-50 dark:bg-gray-700 px-8 py-6 flex justify-center border-b border-gray-100 dark:border-gray-600">
        <%= image_tag "Redmine_logo_v1.png", plugin: 'redmine_asap_theme',
              class: "h-16 w-auto object-contain",
              alt: "Redmine" %>
      </div>

      <%# Corps %>
      <div class="px-6 py-5 space-y-3">
        <div class="flex items-center gap-2 text-sm">
          <span class="font-medium text-gray-500 dark:text-gray-400 w-28 shrink-0"><%= l(:label_version) %></span>
          <span class="text-gray-800 dark:text-gray-100"><%= Redmine::Info.versioned_name %></span>
        </div>
        <div class="flex items-center gap-2 text-sm">
          <span class="font-medium text-gray-500 dark:text-gray-400 w-28 shrink-0">Powered by</span>
          <span class="text-gray-800 dark:text-gray-100">
            <%= link_to Redmine::Info.app_name, Redmine::Info.url,
                  target: '_blank', rel: 'noopener',
                  class: "text-blue-600 dark:text-blue-400 hover:underline" %>
            &copy; 2006-2025 Jean-Philippe Lang
          </span>
        </div>
      </div>

      <%# Footer avec bouton Fermer %>
      <div class="px-6 pb-5 flex justify-end">
        <button data-action="click->application#hide"
                class="text-sm px-4 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-700 dark:text-gray-200 transition cursor-pointer">
          <%= l(:button_close) %>
        </button>
      </div>

    </div>
  </div>
</div>
