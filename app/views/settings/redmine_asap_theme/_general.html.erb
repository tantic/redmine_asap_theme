
<fieldset class="box">
  <legend><%= l(:redmine_asap_theme_turbo) %></legend>
  <div class="tabular settings">
    <p>
      <%= label_tag :redmine_asap_theme_turbo, l(:redmine_asap_theme_turbo) %>
      <%= check_box_tag "settings[redmine_asap_theme_turbo]", true, @settings[:redmine_asap_theme_turbo] %>
    </p>
    <p>
      <%= label_tag :turbo_panel, l(:turbo_panel) %>
      <%= check_box_tag "settings[turbo_panel]", true, @settings[:turbo_panel] %>
    </p>
  </div>
</fieldset>

